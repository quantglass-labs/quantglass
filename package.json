{
  "name": "quantglass",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "backend:backup": "PYTHONPATH=apps/backend ./.venv/bin/python apps/backend/scripts/manage_state_bundle.py export",
    "backend:dev": "PYTHONPATH=apps/backend ./.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "backend:dev:extensions": "QUANTGLASS_ENABLE_EXTENSION_ENTRY_POINTS=true PYTHONPATH=apps/backend ./.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "desktop:dev": "npm --prefix apps/desktop run dev --",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:preview": "npm --prefix apps/desktop run preview --",
    "desktop:tauri:dev": "npm --prefix apps/desktop run tauri:dev --",
    "desktop:tauri:build": "npm --prefix apps/desktop run tauri:build --",
    "backend:bundle": "./.venv/bin/python apps/backend/scripts/build_sidecar.py",
    "desktop:bundle": "npm run backend:bundle && npm run desktop:tauri:build",
    "backend:check": "PYTHONPATH=apps/backend ./.venv/bin/python -c \"from app.main import app; print(app.title, len(app.routes))\"",
    "backend:openapi": "PYTHONPATH=apps/backend ./.venv/bin/python apps/backend/scripts/export_openapi.py",
    "backend:smoke": "PYTHONPATH=apps/backend ./.venv/bin/python -m unittest apps/backend/tests/test_smoke.py",
    "backend:test": "PYTHONPATH=apps/backend ./.venv/bin/python -m pytest apps/backend/tests",
    "license:reports": "./.venv/bin/python scripts/generate_license_reports.py",
    "validate:backend": "npm run backend:check && npm run backend:test && npm run backend:smoke && npm run backend:openapi",
    "validate:release": "npm run validate:backend && npm run desktop:build && npm run backend:bundle && npm run desktop:tauri:build"
  }
}
