    "checkpoints": [
      {
        "at_bar": 33,
        "question": "Three sharp red bars have erased a week of gains. The higher-timeframe trend structure is intact: price is above the prior swing low and the regime gate still reads trending. You hold a position from much lower. What do you do?",
        "options": [
          {
            "id": "panic",
            "label": "Sell everything - protect the profit before it disappears",
            "points": 2,
            "debrief": "Exiting on fear when no invalidation level has been touched means the chart was never in charge - your stomach was. You keep the profit but train the habit of abandoning plans under pressure."
          },
          {
            "id": "check_plan",
            "label": "Re-read the plan: stop is below the swing low, untouched - hold",
            "points": 10,
            "debrief": "Correct. A pullback that stays above your invalidation level is noise by definition. The drawdown-psychology lesson is this exact moment: the plan was written by the calm version of you for the scared version."
          },
          {
            "id": "double",
            "label": "Double the position - it is on sale",
            "points": 3,
            "debrief": "The trend supports adding, but doubling makes risk balloon mid-trade without a new plan. If the swing low breaks you lose far more than the original plan risked. Adds need their own entry, stop, and size."
          }
        ]
      },
      {
        "at_bar": 37,
        "question": "Price has stabilized just above the swing low. You want to add to the position. How do you size the add?",
        "options": [
          {
            "id": "size_risk",
            "label": "Size it so the add risks 1% to the same stop, like any new trade",
            "points": 10,
            "debrief": "Correct. An add is a brand-new trade wearing the old one's jersey. Position-sizing math does not care that you already own some - risk per unit of stop distance is the only sizing input."
          },
          {
            "id": "size_gut",
            "label": "Buy a round number that feels meaningful",
            "points": 0,
            "debrief": "Round-number sizing means risk is whatever the chart decides later. The sizing lesson exists because 'felt right' is how 5% losses happen with a 1% policy."
          },
          {
            "id": "all_in",
            "label": "Use all remaining buying power - conviction is high",
            "points": 0,
            "debrief": "Conviction is an emotion wearing a suit. All-in sizing makes one adverse bar fatal, and the engine's Monte Carlo lesson shows how fast full-size losing streaks bankrupt an account."
          }
        ]
      },
      {
        "at_bar": 50,
        "question": "The trend resumed and the position is well in profit. The original target is close. What is the disciplined finish?",
        "options": [
          {
            "id": "move_target",
            "label": "Cancel the target - this one is going much higher",
            "points": 2,
            "debrief": "Maybe it is - but abandoning the written exit converts a tested plan into improvisation at the moment of maximum greed. If you want a trail-instead-of-target system, design it before the next trade, not during this one."
          },
          {
            "id": "follow_plan",
            "label": "Let the target or a trailed stop take you out, per the plan",
            "points": 10,
            "debrief": "Correct. Exits decided in advance are the half of trading nobody journals about. An earned win only counts as one if the process that produced it can be repeated."
          },
          {
            "id": "exit_now",
            "label": "Sell immediately - lock it in before anything changes",
            "points": 5,
            "debrief": "Taking profit is never ruinous, but exiting early out of fear systematically shrinks winners while stops keep losses full-size. Over a hundred trades that asymmetry is the difference between positive and negative expectancy."
          }
        ]
      }
    ]
