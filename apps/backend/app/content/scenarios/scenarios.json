    "checkpoints": [
      {
        "at_bar": 30,
        "question": "Price just closed above the range high on the biggest volume bar in weeks. Everyone on the feed is calling the breakout. What do you do?",
        "options": [
          {
            "id": "chase",
            "label": "Buy at market right now before it runs away",
            "points": 0,
            "debrief": "Buying the first euphoric close is chasing: your entry sits far from any invalidation level, so your stop is either huge or arbitrary. The engine's first-touch math is unforgiving - a wide stop turns a normal pullback into a full loss."
          },
          {
            "id": "plan",
            "label": "Define the trade first: entry on retest, stop below the breakout bar, target from the range height",
            "points": 10,
            "debrief": "Correct. A breakout is a hypothesis, not a result. Writing entry, stop, and target before committing capital is what the process score rewards - and it is the only version of this trade with defined risk."
          },
          {
            "id": "fomo_small",
            "label": "Buy a half position now, figure out the stop later",
            "points": 3,
            "debrief": "Smaller size limits the damage but 'figure out the stop later' means the trade has no invalidation. A small bad trade is still a bad trade - the journal will score it stopless."
          }
        ]
      },
      {
        "at_bar": 34,
        "question": "The breakout is stalling. Price has spent four bars going sideways just above the old range high, and volume is fading. Your planned retest entry filled, stop below the breakout bar. Now what?",
        "options": [
          {
            "id": "widen",
            "label": "Widen the stop below the whole range - give it room to breathe",
            "points": 0,
            "debrief": "Widening a stop after entry is the single most corrosive habit in trading: it converts a planned small loss into an unplanned large one. The constitution exists precisely to forbid this."
          },
          {
            "id": "hold",
            "label": "Do nothing - the plan is intact until the stop is hit",
            "points": 10,
            "debrief": "Correct. Fading volume is uncomfortable but it is not your invalidation level. A plan only works if the plan, not the discomfort, makes the decisions."
          },
          {
            "id": "add",
            "label": "Add to the position - lower average entry before it resumes",
            "points": 2,
            "debrief": "Adding into a stalling breakout increases risk exactly when the evidence is weakening. If the stop is hit you now lose more than the plan ever allowed."
          }
        ]
      },
      {
        "at_bar": 44,
        "question": "The breakout failed. Your stop was hit two bars ago for a planned -1R loss, and price is now in free fall below the old range. How do you close the episode?",
        "options": [
          {
            "id": "revenge",
            "label": "Short it right now - it owes you",
            "points": 0,
            "debrief": "This is revenge trading: the entry reason is your loss, not the market. The psychology track calls this tilt, and the journal's emotion tag exists to catch exactly this moment."
          },
          {
            "id": "journal",
            "label": "Log the trade: planned loss, stop respected, write what the fakeout looked like",
            "points": 10,
            "debrief": "Correct. This is a well-played loss - good decision, bad outcome. The 2x2 classifier exists because traders who can take a -1R without flinching are the ones still solvent after a hundred trades."
          },
          {
            "id": "stew",
            "label": "Walk away and skip journaling - it was just a loser",
            "points": 4,
            "debrief": "Walking away beats revenge trading, but an unjournaled loss teaches nothing. The fakeout's signature - the fading retest volume - is the lesson you paid for."
          }
        ]
      }
    ]
  },
