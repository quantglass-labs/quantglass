    "checkpoints": [
      {
        "at_bar": 27,
        "question": "The market gapped down through your stop overnight - you are out at a worse price than planned, roughly -1.8R instead of -1R. The tape is violent. First decision?",
        "options": [
          {
            "id": "win_back",
            "label": "Trade the volatility hard - this is where fortunes are made",
            "points": 0,
            "debrief": "Trading to win back a loss is the textbook tilt entry. Volatile regimes punish exactly this: spreads widen, stops slip, and the engine's volatile-override gate exists because edges measured in calm markets do not transfer here."
          },
          {
            "id": "stand_down",
            "label": "Accept the slippage, halve all position sizing, reassess at the close",
            "points": 10,
            "debrief": "Correct. Gap slippage past a stop is a cost of trading, not a betrayal. Cutting size when realized volatility doubles is what keeps -1.8R an annoyance instead of the first domino."
          },
          {
            "id": "reenter",
            "label": "Re-enter the same trade immediately - the thesis has not changed",
            "points": 2,
            "debrief": "The thesis may stand but the regime has changed: stop distances computed from yesterday's ATR are wrong today. Re-entry needs a new plan sized to the new volatility, not a reflex."
          }
        ]
      },
      {
        "at_bar": 33,
        "question": "Mid-chop, a position you re-planned and entered with a stop is down but not stopped. A friend messages: 'just average down, it always bounces.' What do you do?",
        "options": [
          {
            "id": "average",
            "label": "Average down - lower the break-even point",
            "points": 0,
            "debrief": "Averaging down without a plan is how single trades kill accounts: each add moves break-even closer and total risk further. Every blow-up post-mortem contains this step."
          },
          {
            "id": "respect",
            "label": "Keep the position and the stop exactly as planned",
            "points": 10,
            "debrief": "Correct. The trade is behaving inside its planned envelope. Outside advice mid-trade is noise - your written plan is the only voice with a track record."
          },
          {
            "id": "exit_flat",
            "label": "Close it - flat feels safer in this tape",
            "points": 5,
            "debrief": "Going flat is a legitimate volatility response, but the time for that call was the post-gap reassessment. Exiting mid-plan on feel still trains the improvisation habit, just in a safer direction."
          }
        ]
      },
      {
        "at_bar": 42,
        "question": "The chop resolved upward and your re-planned trade hit its target. Net, the day went: gapped loss, disciplined re-plan, full winner. The honest debrief is:",
        "options": [
          {
            "id": "hero",
            "label": "I traded a crash brilliantly - size up next time",
            "points": 0,
            "debrief": "One survived shock is not a skill sample. Calling it brilliance and sizing up is the dangerous-success pattern: the outcome was partly variance, and doubling exposure prices the next gap at ruin."
          },
          {
            "id": "process",
            "label": "The system worked: sizing cut, plans rewritten, stops respected - log all of it",
            "points": 10,
            "debrief": "Correct. The win matters less than the sequence that produced it: stand down, resize, re-plan, obey stops. That sequence is reusable; the bounce was not yours to claim."
          },
          {
            "id": "lucky",
            "label": "Pure luck - nothing to learn from chaos",
            "points": 3,
            "debrief": "Humility beats heroics, but 'nothing to learn' is wrong: you have a journaled record of conduct under a liquidity shock. That record - not the P&L - is what the expert psychology bar measures."
          }
        ]
      }
