{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantglass.dev/schemas/lesson.schema.json",
  "title": "QuantGlass lesson",
  "type": "object",
  "required": [
    "id",
    "module_id",
    "track_id",
    "tier",
    "order",
    "title",
    "summary",
    "concept",
    "key_terms",
    "exercise",
    "live_apply"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(novice|intermediate|advanced|expert)-[0-9]{2}-[a-z0-9-]+$"
    },
    "module_id": {
      "enum": [
        "novice",
        "intermediate",
        "advanced",
        "expert"
      ]
    },
    "tier": {
      "enum": [
        "novice",
        "intermediate",
        "advanced",
        "expert"
      ]
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "concept": {
      "type": "string",
      "minLength": 50
    },
    "key_terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "term",
          "definition"
        ],
        "additionalProperties": false,
        "properties": {
          "term": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "exercise": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "question",
            "options",
            "correct_index",
            "explanation"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "multiple_choice"
            },
            "question": {
              "type": "string",
              "minLength": 10
            },
            "options": {
              "type": "array",
              "minItems": 2,
              "maxItems": 6,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "correct_index": {
              "type": "integer",
              "minimum": 0
            },
            "explanation": {
              "type": "string",
              "minLength": 10
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "question",
            "correct_answer",
            "explanation"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "numeric_input"
            },
            "question": {
              "type": "string",
              "minLength": 10
            },
            "hint": {
              "type": "string"
            },
            "correct_answer": {
              "type": "string",
              "pattern": "^[0-9.,-]+$"
            },
            "tolerance_percent": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 25
            },
            "explanation": {
              "type": "string",
              "minLength": 10
            }
          }
        }
      ]
    },
    "live_apply": {
      "type": "object",
      "required": [
        "screen",
        "cta"
      ],
      "additionalProperties": false,
      "properties": {
        "screen": {
          "enum": [
            "dashboard",
            "signals",
            "symbol-detail",
            "watchlist",
            "backtest",
            "alerts",
            "settings",
            "learn"
          ]
        },
        "cta": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "track_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "live_exercise": {
      "enum": [
        "atr_stop",
        "position_size",
        "target_price",
        "round_trip_cost",
        "stop_distance_pct"
      ]
    },
    "visuals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": [
              "candle_anatomy",
              "candle_comparison",
              "magnitude_bars",
              "flowchart",
              "labeled_inputs",
              "process_steps",
              "mini_chart",
              "candle_builder",
              "risk_sandbox",
              "indicator_playground",
              "auction_sim",
              "payoff_explorer",
              "regime_scrubber",
              "monte_carlo",
              "conformal_visualizer"
            ]
          },
          "title": {
            "type": "string"
          },
          "params": {
            "type": "object"
          }
        }
      }
    }
  }
}
